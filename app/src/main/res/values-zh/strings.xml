    <string name="onboarding_page_welcome_title">欢迎使用 Project Lumen</string>
    <string name="onboarding_page_welcome_message">这个快速设置会准备护眼防护、本地统计，并生成用于后端上报的私有 64 位设备指纹。</string>
    <string name="onboarding_page_welcome_bullet_1">指纹由本机设备档案生成：型号、Android 版本和 SDK、主 ABI、Build fingerprint 以及 Android ID。</string>
    <string name="onboarding_page_welcome_bullet_2">Project Lumen 默认把核心计时和健康历史保存在本地。</string>
    <string name="onboarding_page_welcome_bullet_3">完成设置后，你仍然可以在设置页调整所有选项。</string>
    <string name="onboarding_page_protection_title">先启用基础防护</string>
    <string name="onboarding_page_protection_message">推荐设置会打开多数用户上手前最需要的每日护眼闭环。</string>
    <string name="onboarding_page_protection_bullet_1">使用 20-20-20 提醒，定期进行短休息。</string>
    <string name="onboarding_page_protection_bullet_2">保持统计开启，报告才能发现连续用眼过久的问题。</string>
    <string name="onboarding_page_protection_bullet_3">需要专注工作和长休息时，再配合番茄钟。</string>
    <string name="onboarding_page_permissions_title">按提示完成权限</string>
    <string name="onboarding_page_permissions_message">部分防护能力需要 Android 权限页确认后才能稳定工作。</string>
    <string name="onboarding_page_permissions_bullet_1">允许通知，休息提醒才能准时出现。</string>
    <string name="onboarding_page_permissions_bullet_2">只有需要距离和眨眼检测时才授予摄像头权限。</string>
    <string name="onboarding_page_permissions_bullet_3">悬浮窗、闹钟、亮度和 Shizuku 适合更严格的防护需求。</string>
    <string name="onboarding_page_cloud_title">谨慎选择云端和诊断</string>
    <string name="onboarding_page_cloud_message">远端能力用于账号同步、权益刷新、云备份和带签名的诊断上报。</string>
    <string name="onboarding_page_cloud_bullet_1">只有需要云备份或跨设备同步时再登录。</string>
    <string name="onboarding_page_cloud_bullet_2">诊断上传默认关闭，并使用 64 位设备指纹关联设备。</string>
    <string name="onboarding_page_cloud_bullet_3">崩溃报告和应用清单上传需要单独同意。</string>
    <string name="onboarding_page_best_practice_title">示例最佳实践</string>
    <string name="onboarding_page_best_practice_message">一个实用配置很简单：保持提醒开启、收集本地统计，并在活跃几天后查看健康报告。</string>
    <string name="onboarding_page_best_practice_bullet_1">工作 20 分钟后，看向至少 6 米外的物体 20 秒。</string>
    <string name="onboarding_page_best_practice_bullet_2">屏幕保持约一臂距离；姿势变化后重新校准距离。</string>
    <string name="onboarding_page_best_practice_bullet_3">夜间降低亮度；如果反复收到低光警告，就应该停止继续用眼。</string>
